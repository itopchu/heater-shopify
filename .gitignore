!catalog/manifest.json

# Audit / perf artifacts
lighthouse-reports/
storefront-root.html
tmp/

# Image-to-3D experiment (parked 2026-04-30 — see memory/project_3d_pipeline_parked.md).
# Trellis + Hunyuan3D-2.1 both fail on radiator geometry. Scripts kept on disk as
# evidence, but not tracked in git since the pipeline is not part of the build.
agent/scripts/trellis-sample.mjs
agent/scripts/3d-shootout.mjs

# Claude harness state
.claude/
.vercel

# Internal planning / audit / scratch — private dev info, not for repo
docs/
.notes/
*.local.md
*-private.md
# Personal AI-assistant instructions — keep local, never publish (.claude/ already ignored above)
CLAUDE.md

# Translation cache (regenerable from agent/scripts/prod-translate-content.mjs)
.translation-cache/

# Unlighthouse / Pa11y output
.unlighthouse-reports/
.lighthouse-runs/
pa11y-results.json

