data/*-prod-snapshot.json
data/image-binding-audit-*.csv
data/qa-images/

# One-off scratch dirs (sharp REPL etc. — not part of the workspace)
sharp-tool/

# Shopify Function extension build artifacts (regenerated by `shopify app build`)
extensions/*/dist/
extensions/*/schema.graphql
