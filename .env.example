# Copy to .env.local (gitignored) and fill in. Never commit real values.

# Claude Agent SDK
ANTHROPIC_API_KEY=

# Shopify — DEV store (default target for the agent)
SHOPIFY_DEV_STORE=heater-dev.myshopify.com
SHOPIFY_DEV_ADMIN_TOKEN=

# Shopify — PROD store (only set when production is provisioned)
SHOPIFY_PROD_STORE=
SHOPIFY_PROD_ADMIN_TOKEN=

# Agent runtime
AGENT_DEFAULT_STORE=dev
AGENT_SESSION_TOKEN_CAP_INPUT=2000000
AGENT_SESSION_TOKEN_CAP_OUTPUT=500000
