# Copy to .env.local (gitignored) and fill in. Never commit real values.

# Claude Agent SDK authentication
#   The SDK uses the Claude Code CLI runtime, which is authenticated to your
#   Claude Max subscription via `claude /login`. No API key needed in that mode.
#   Set ANTHROPIC_API_KEY only if you switch to pay-per-token API billing later.
ANTHROPIC_API_KEY=

# Shopify — DEV store (default target for the agent)
SHOPIFY_DEV_STORE=heater-dev.myshopify.com
SHOPIFY_DEV_ADMIN_TOKEN=

# Shopify — PROD store (only set when production is provisioned)
SHOPIFY_PROD_STORE=
SHOPIFY_PROD_ADMIN_TOKEN=

# Agent runtime
#   AGENT_DEFAULT_STORE=prod is forbidden — production targeting must be acknowledged
#   on the command line via `--store prod`. Leave this at "dev" or unset.
AGENT_DEFAULT_STORE=dev
AGENT_SESSION_TOKEN_CAP_INPUT=2000000
AGENT_SESSION_TOKEN_CAP_OUTPUT=500000
#   Comma-separated list of domain suffixes that are considered "dev" stores.
#   resolveStore() asserts: dev keys end with one of these, prod keys do not.
#   Default: "-dev.myshopify.com". Add "-staging.myshopify.com" etc. as needed.
AGENT_DEV_DOMAIN_ALLOWLIST=-dev.myshopify.com

# Catalog sync pipeline (agent/sync/)
#   Image regeneration via Google Gemini (@google/genai).
#   Get an API key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=
#   Gemini image model. Default is Nano Banana (fast, cheap, good).
#   Swap to gemini-3-pro-image-preview (Nano Banana Pro) for highest fidelity.
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
#   Hard cap on images generated per sync run (cost guard). Default 50.
IMAGE_GEN_CAP=50
#   Global pause switch. When "1", sync skips image generation entirely —
#   cached images are reused, new products get no images. Use while tuning
#   the prompt template in agent/sync/images.ts to avoid burning budget on
#   low-quality generations.
SYNC_SKIP_IMAGES=0
#   If 1, sync defaults to --dry-run unless --no-dry-run passed.
SYNC_DRY_RUN_DEFAULT=1
#   Upstream catalog source.
XXL_SOURCE_BASE_URL=https://xxl-heizung.de
#   Optional: pin a specific API version for the sync pipeline's Admin calls.
SHOPIFY_API_VERSION=2026-04

# ---------------------------------------------------------------------------
# Hydrogen storefront (apps/store-heating-hydrogen) — Oxygen environment vars
# ---------------------------------------------------------------------------
#   These are NOT read by the agent; set them on the Oxygen deployment
#   environment (or the Hydrogen app's local .env) — listed here for reference.
#
#   Search Console / Bing Webmaster ownership-verification tokens. When set,
#   root.tsx emits the matching <meta> tags. Leave empty until the consoles
#   are created.
PUBLIC_GOOGLE_SITE_VERIFICATION=
PUBLIC_BING_SITE_VERIFICATION=

# ---------------------------------------------------------------------------
# SEO ops scripts
# ---------------------------------------------------------------------------
#   GA4 Measurement ID (G-XXXXXXXXXX). Consumed by
#   agent/scripts/install-ga4-web-pixel.mjs to register a Shopify Customer
#   Events web pixel that loads gtag.js (consent-aware, no theme edits).
GA4_MEASUREMENT_ID=
#   agent/scripts/submit-sitemaps.mjs — Google Search Console API service-
#   account JSON key path (the service account must be an owner of the GSC
#   property) and Bing Webmaster Tools API key (Webmaster Tools → Settings →
#   API access). Canonical site URL the sitemaps live under.
GSC_SERVICE_ACCOUNT_JSON=
BING_WEBMASTER_API_KEY=
SEO_SITE_URL=https://www.gberg-heizung.de
