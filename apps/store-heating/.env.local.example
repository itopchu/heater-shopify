# Copy to apps/store-heating/.env.local (gitignored) and fill in.
#
# Storefront API access — different from Admin API.
# Create one in Shopify Admin (heater-dev.myshopify.com):
#   1. Settings → Apps and sales channels → Develop apps
#   2. Click "Allow custom app development" if not already enabled
#   3. Click "Create an app" — name it e.g. "Storefront — store-heating"
#   4. Configuration → Storefront API integration → enable scopes:
#        unauthenticated_read_product_listings
#        unauthenticated_read_product_inventory
#        unauthenticated_read_product_tags
#        unauthenticated_read_collection_listings
#        unauthenticated_read_metaobjects
#        unauthenticated_read_content
#   5. Save → Install app → copy the Storefront API access token
#
SHOPIFY_STORE_DOMAIN=heater-dev.myshopify.com
SHOPIFY_STOREFRONT_TOKEN=
SHOPIFY_API_VERSION=2024-10

# Defaults for the locale segment in route /[locale]
NEXT_PUBLIC_DEFAULT_LOCALE=nl
NEXT_PUBLIC_DEFAULT_COUNTRY=NL
