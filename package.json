{
  "name": "heater-shopify-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "G-Berg Heizung — Shopify theme + Claude Agent SDK harness + Next.js multi-brand storefront monorepo.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "agent": "tsx agent/src/index.ts",
    "agent:test": "tsx agent/src/test/scope-leak.ts",
    "test": "pnpm --filter store-heating-hydrogen test && pnpm agent:test",
    "test:hydrogen": "pnpm --filter store-heating-hydrogen test",
    "seo:submit-sitemaps": "node agent/scripts/submit-sitemaps.mjs",
    "seo:install-redirects": "node agent/scripts/install-product-redirects.mjs --store prod",
    "seo:install-ga4": "node agent/scripts/install-ga4-web-pixel.mjs --store prod",
    "seo:build-og-image": "node agent/scripts/build-og-default-image.mjs",
    "sync": "tsx agent/sync/index.ts",
    "sync:dry": "tsx agent/sync/index.ts --dry-run",
    "qa:lighthouse": "pnpm dlx unlighthouse --config-file qa/unlighthouse.config.ts",
    "qa:a11y": "pnpm dlx pa11y-ci --config qa/.pa11yci.json",
    "qa:full": "pnpm qa:lighthouse && pnpm qa:a11y",
    "seed:widerruf": "node agent/scripts/seed-widerrufsbelehrung.mjs",
    "enable:extra-locales": "node agent/scripts/enable-extra-locales.mjs",
    "install:metafields:design-refresh": "node agent/scripts/install-design-refresh-metafields.mjs --store dev",
    "install:metafields:design-refresh:dry": "node agent/scripts/install-design-refresh-metafields.mjs --store dev --dry-run",
    "translate:faqs": "node agent/scripts/translate-faq-metaobjects.mjs",
    "typecheck": "pnpm --filter @gberg/product-schema --filter @gberg/shopify-client --filter @gberg/theme-tokens --filter @gberg/ui typecheck && tsc --noEmit",
    "dev:heating": "pnpm --filter store-heating dev",
    "build:heating": "pnpm --filter store-heating build",
    "dev:hydrogen": "pnpm --filter store-heating-hydrogen dev",
    "build:hydrogen": "pnpm --filter store-heating-hydrogen build",
    "preview:hydrogen": "pnpm --filter store-heating-hydrogen preview",
    "deploy:hydrogen": "pnpm --filter store-heating-hydrogen deploy",
    "lint": "pnpm -r --if-present lint",
    "clean": "pnpm -r --if-present clean"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "@google/genai": "^0.10.0",
    "adm-zip": "^0.5.17",
    "dotenv": "^16.4.5",
    "sanitize-html": "^2.17.3",
    "sharp": "^0.34.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/sanitize-html": "^2.16.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
