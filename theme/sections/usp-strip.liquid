{%- comment -%}
  USP strip — reads the `usp_item` metaobject.
  Merchant edits entries in Admin → Content → Metaobjects → USP item.
  Designed for 4 items; limit setting lets merchant show fewer.
{%- endcomment -%}

{%- style -%}
  .usp-strip-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  .usp-strip__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem 1rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }
  .usp-strip__item {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }
  .usp-strip__icon {
    width: 32px;
    height: 32px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .usp-strip__icon img,
  .usp-strip__icon svg {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  .usp-strip__text { display: flex; flex-direction: column; gap: 0.125rem; }
  .usp-strip__label {
    /* Color and red rule above are applied by component-gberg-premium.css.
       Keep base typography here so the section renders sanely if that
       stylesheet ever fails to load. */
    font-weight: 600;
    font-size: 1rem;
    line-height: 1.3;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #111111;
    margin: 0 0 0.25rem;
  }
  .usp-strip__body {
    font-size: 0.9375rem;
    line-height: 1.5;
    color: #111111; /* charcoal — 19.13:1 contrast on white */
    margin: 0;
  }

  @media (min-width: 990px) {
    .usp-strip-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
    .usp-strip__grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 2rem;
    }
    {% if section.settings.alignment == 'center' %}
      .usp-strip__item { flex-direction: column; align-items: center; text-align: center; }
      .usp-strip__icon { width: 40px; height: 40px; }
    {% endif %}
  }
{%- endstyle -%}

<div class="usp-strip-{{ section.id }} color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width">
    {%- assign items = shop.metaobjects.usp_item.values -%}
    {%- if items.size > 0 -%}
      <ul class="usp-strip__grid" role="list">
        {%- for item in items -%}
          {%- if section.settings.limit > 0 and forloop.index > section.settings.limit -%}
            {%- break -%}
          {%- endif -%}
          <li class="usp-strip__item">
            {%- if item.icon != blank -%}
              <div class="usp-strip__icon" aria-hidden="true">
                {%- if item.icon.image -%}
                  {{ item.icon | image_url: width: 80 | image_tag: loading: 'lazy', alt: '', width: 40, height: 40 }}
                {%- else -%}
                  <img src="{{ item.icon | file_url }}" alt="" loading="lazy" width="40" height="40">
                {%- endif -%}
              </div>
            {%- endif -%}
            <div class="usp-strip__text">
              {%- if item.label != blank -%}
                <p class="usp-strip__label">{{ item.label }}</p>
              {%- endif -%}
              {%- if item.body != blank -%}
                <p class="usp-strip__body">{{ item.body }}</p>
              {%- endif -%}
            </div>
          </li>
        {%- endfor -%}
      </ul>
    {%- else -%}
      {%- if request.design_mode -%}
        <p style="text-align: center; opacity: 0.6;">
          No USP items yet. Add entries in Admin → Content → Metaobjects → USP item.
        </p>
      {%- endif -%}
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "USP strip",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Reads USP item metaobjects. Edit entries in Admin → Content → Metaobjects → USP item."
    },
    {
      "type": "range",
      "id": "limit",
      "min": 0,
      "max": 8,
      "step": 1,
      "default": 4,
      "label": "Max items to show",
      "info": "0 = show all"
    },
    {
      "type": "select",
      "id": "alignment",
      "options": [
        { "value": "left", "label": "Left (icon beside text)" },
        { "value": "center", "label": "Center (icon above text)" }
      ],
      "default": "left",
      "label": "Desktop alignment"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 32
    }
  ],
  "presets": [
    {
      "name": "USP strip"
    }
  ]
}
{% endschema %}
