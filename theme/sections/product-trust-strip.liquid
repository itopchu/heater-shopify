{%- comment -%}
  PDP trust strip — compact inline version of trust-badges for PDPs.
  Reads the same `trust_badge` metaobjects but renders in a single horizontal row.
{%- endcomment -%}

{%- style -%}
  .ptrust-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  .ptrust__list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem 1.5rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }
  .ptrust__item {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    font-weight: 500;
  }
  .ptrust__icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .ptrust__icon img,
  .ptrust__icon svg {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  @media (min-width: 750px) {
    .ptrust-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
    .ptrust__item { font-size: 0.875rem; }
  }
{%- endstyle -%}

<div class="ptrust-{{ section.id }} color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width">
    {%- assign badges = shop.metaobjects.trust_badge.values -%}
    {%- if badges.size > 0 -%}
      <ul class="ptrust__list" role="list">
        {%- for badge in badges -%}
          {%- if section.settings.limit > 0 and forloop.index > section.settings.limit -%}
            {%- break -%}
          {%- endif -%}
          <li class="ptrust__item">
            {%- if badge.icon != blank -%}
              <span class="ptrust__icon" aria-hidden="true">
                {%- if badge.icon.image -%}
                  {{ badge.icon | image_url: width: 40 | image_tag: loading: 'lazy', alt: '', width: 20, height: 20 }}
                {%- else -%}
                  <img src="{{ badge.icon | file_url }}" alt="" loading="lazy" width="20" height="20">
                {%- endif -%}
              </span>
            {%- endif -%}
            {%- if badge.label != blank -%}
              <span>{{ badge.label }}</span>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Product: trust strip",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Compact trust badge row for PDPs. Reads trust_badge metaobjects."
    },
    {
      "type": "range",
      "id": "limit",
      "min": 0,
      "max": 8,
      "step": 1,
      "default": 4,
      "label": "Max items",
      "info": "0 = show all"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 16
    }
  ],
  "presets": [
    {
      "name": "Product: trust strip"
    }
  ],
  "enabled_on": {
    "templates": ["product"]
  }
}
{% endschema %}
