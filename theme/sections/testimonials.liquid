{%- comment -%}
  Testimonials carousel — reads the `testimonial` metaobject.
  Merchant edits entries in Admin → Content → Metaobjects → Testimonial.
  All section-level copy (title, kicker) is editable in Theme Editor.
{%- endcomment -%}

{%- style -%}
  .testimonials-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  .testimonials__header {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .testimonials__kicker {
    display: inline-block;
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 0.5rem;
    opacity: 0.65;
  }
  .testimonials__title {
    margin: 0;
  }
  .testimonials__list {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: 85%;
    gap: 1rem;
    padding: 0;
    margin: 0;
    list-style: none;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }
  .testimonials__list::-webkit-scrollbar {
    display: none;
  }
  .testimonials__card {
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 2rem 1.5rem;
    border-radius: 12px;
    background: rgb(var(--color-background));
    box-shadow: 0 1px 3px rgba(var(--color-shadow, 0, 0, 0), 0.05);
  }
  .testimonials__rating {
    display: inline-flex;
    gap: 2px;
    color: #D4A12E;
  }
  .testimonials__rating svg {
    width: 18px;
    height: 18px;
  }
  .testimonials__quote {
    font-size: 1.0625rem;
    line-height: 1.55;
    margin: 0;
    flex: 1;
  }
  .testimonials__author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: auto;
  }
  .testimonials__avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    background: rgba(var(--color-foreground), 0.08);
  }
  .testimonials__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .testimonials__author-name {
    font-weight: 600;
    font-size: 0.9375rem;
    margin: 0;
    line-height: 1.2;
  }
  .testimonials__author-role {
    font-size: 0.8125rem;
    opacity: 0.65;
    margin: 0;
    line-height: 1.4;
  }
  .testimonials__source {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    opacity: 0.55;
    margin: 0;
  }

  @media (min-width: 750px) {
    .testimonials-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
    .testimonials__list {
      grid-auto-columns: calc((100% - 2 * 1.5rem) / 3);
      gap: 1.5rem;
    }
  }

  @media (min-width: 1100px) {
    .testimonials__list {
      grid-auto-columns: calc((100% - 3 * 1.5rem) / 4);
    }
  }
{%- endstyle -%}

<div class="testimonials-{{ section.id }} color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width">
    {%- if section.settings.title != blank or section.settings.kicker != blank -%}
      <header class="testimonials__header">
        {%- if section.settings.kicker != blank -%}
          <span class="testimonials__kicker">{{ section.settings.kicker }}</span>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
          <h2 class="testimonials__title {{ section.settings.heading_size }}">
            {{ section.settings.title }}
          </h2>
        {%- endif -%}
      </header>
    {%- endif -%}

    {%- assign entries = shop.metaobjects.testimonial.values -%}
    {%- if entries.size > 0 -%}
      <ul class="testimonials__list" role="list">
        {%- for t in entries -%}
          {%- if section.settings.limit > 0 and forloop.index > section.settings.limit -%}
            {%- break -%}
          {%- endif -%}
          <li class="testimonials__card">
            {%- if t.rating != blank -%}
              <span class="testimonials__rating" aria-label="{{ t.rating }} / 5">
                {%- for i in (1..5) -%}
                  {%- if i <= t.rating.value -%}
                    <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M10 1.5l2.6 5.3 5.9.86-4.25 4.15 1 5.86L10 14.9l-5.25 2.77 1-5.86L1.5 7.66l5.9-.86L10 1.5z"/></svg>
                  {%- else -%}
                    <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M10 1.5l2.6 5.3 5.9.86-4.25 4.15 1 5.86L10 14.9l-5.25 2.77 1-5.86L1.5 7.66l5.9-.86L10 1.5z"/></svg>
                  {%- endif -%}
                {%- endfor -%}
              </span>
            {%- endif -%}

            {%- if t.quote != blank -%}
              <blockquote class="testimonials__quote">{{ t.quote }}</blockquote>
            {%- endif -%}

            <div class="testimonials__author">
              {%- if t.avatar != blank -%}
                <div class="testimonials__avatar">
                  {{ t.avatar | image_url: width: 80 | image_tag: loading: 'lazy', alt: t.name | default: '' }}
                </div>
              {%- endif -%}
              <div>
                {%- if t.name != blank -%}
                  <p class="testimonials__author-name">{{ t.name }}</p>
                {%- endif -%}
                {%- if t.role != blank -%}
                  <p class="testimonials__author-role">{{ t.role }}</p>
                {%- endif -%}
              </div>
            </div>

            {%- if t.source != blank -%}
              <p class="testimonials__source">{{ t.source }}</p>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    {%- else -%}
      {%- if request.design_mode -%}
        <p style="text-align: center; opacity: 0.6;">
          No testimonials yet. Add entries in Admin → Content → Metaobjects → Testimonial.
        </p>
      {%- endif -%}
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Reads Testimonial metaobjects. Edit entries in Admin → Content → Metaobjects → Testimonial."
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker (small overline)",
      "default": "Customer stories"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Heading",
      "default": "What our customers say."
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Medium" },
        { "value": "h1", "label": "Large" },
        { "value": "h0", "label": "Extra large" }
      ],
      "default": "h2",
      "label": "Heading size"
    },
    {
      "type": "range",
      "id": "limit",
      "min": 0,
      "max": 20,
      "step": 1,
      "default": 0,
      "label": "Max testimonials to show",
      "info": "0 = show all"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 72
    }
  ],
  "presets": [
    {
      "name": "Testimonials"
    }
  ]
}
{% endschema %}
