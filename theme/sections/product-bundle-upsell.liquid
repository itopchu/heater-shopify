{%- comment -%}
  PDP bundle upsell — "Spare im Set" card.
  Reads product.metafields.custom.bundle_partner (product_reference).
{%- endcomment -%}

{%- assign bundle = product.metafields.custom.bundle_partner.value -%}

{%- if bundle != blank or request.design_mode -%}
  {%- style -%}
    .pbundle-{{ section.id }} {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }
    .pbundle__card {
      display: grid;
      grid-template-columns: 96px 1fr auto;
      align-items: center;
      gap: 1rem;
      padding: 1rem;
      border-radius: 12px;
      background: rgba(var(--color-foreground), 0.03);
      border: 1px solid rgba(var(--color-foreground), 0.1);
      max-width: 52rem;
      margin: 0 auto;
      text-decoration: none;
      color: inherit;
    }
    .pbundle__card:hover { background: rgba(var(--color-foreground), 0.05); }
    .pbundle__image { width: 96px; height: 96px; border-radius: 8px; overflow: hidden; background: rgb(var(--color-background)); }
    .pbundle__image img { width: 100%; height: 100%; object-fit: cover; }
    .pbundle__body { display: flex; flex-direction: column; gap: 0.25rem; min-width: 0; }
    .pbundle__kicker { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.06em; opacity: 0.65; margin: 0; }
    .pbundle__title { font-weight: 600; font-size: 1rem; margin: 0; line-height: 1.3; overflow: hidden; text-overflow: ellipsis; }
    .pbundle__price { font-size: 0.875rem; opacity: 0.85; margin: 0; }
    .pbundle__cta {
      display: inline-flex; align-items: center; justify-content: center;
      padding: 0.5rem 0.875rem;
      border-radius: 8px;
      background: rgb(var(--color-button));
      color: rgb(var(--color-button-text));
      font-weight: 600;
      font-size: 0.8125rem;
      white-space: nowrap;
    }

    @media (min-width: 750px) {
      .pbundle-{{ section.id }} {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }
  {%- endstyle -%}

  <div class="pbundle-{{ section.id }} color-{{ section.settings.color_scheme }} gradient">
    <div class="page-width">
      {%- if bundle != blank -%}
        <a href="{{ bundle.url }}" class="pbundle__card">
          <div class="pbundle__image">
            {%- if bundle.featured_image -%}
              {{ bundle.featured_image | image_url: width: 200 | image_tag: loading: 'lazy', alt: bundle.title, width: 96, height: 96 }}
            {%- endif -%}
          </div>
          <div class="pbundle__body">
            <p class="pbundle__kicker">{{ section.settings.kicker }}</p>
            <p class="pbundle__title">{{ bundle.title }}</p>
            <p class="pbundle__price">{{ bundle.price | money_with_currency }}</p>
          </div>
          <span class="pbundle__cta">{{ section.settings.cta }}</span>
        </a>
      {%- elsif request.design_mode -%}
        <p style="text-align: center; opacity: 0.6;">
          No bundle partner set. Link one in Admin → Products → [this product] → Metafields → Bundle partner.
        </p>
      {%- endif -%}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Product: bundle upsell",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Spare im Set"
    },
    {
      "type": "text",
      "id": "cta",
      "label": "CTA text",
      "default": "Ansehen"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 32
    }
  ],
  "presets": [
    {
      "name": "Product: bundle upsell"
    }
  ],
  "enabled_on": {
    "templates": ["product"]
  }
}
{% endschema %}
