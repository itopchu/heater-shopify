        "step3": {
          "type": "column",
          "settings": {
            "title": "Pick your finish",
            "text": "<p>Anthrazit, Schwarz or Weiß — each finish ships with the same EU-warranted core and 10-year corrosion guarantee.</p>",
            "link_label": "",
            "link": ""
          }
        }
      },
      "block_order": ["step1", "step2", "step3"]
