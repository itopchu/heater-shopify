{
  "sections": {
    "hero": {
      "type": "image-banner",
      "blocks": {
        "heading": {
          "type": "heading",
          "settings": {
            "heading": "Warmth that feels like home.",
            "heading_size": "h0"
          }
        },
        "text": {
          "type": "text",
          "settings": {
            "text": "Design radiators for every room — TÜV-tested, 10-year warranty, free EU delivery.",
