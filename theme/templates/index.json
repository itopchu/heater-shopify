        "c3": { "type": "featured_collection", "settings": { "collection": "handtuchwaermer" } },
        "c4": { "type": "featured_collection", "settings": { "collection": "austauschheizkorper" } },
        "c5": { "type": "featured_collection", "settings": { "collection": "zubehoer" } }
