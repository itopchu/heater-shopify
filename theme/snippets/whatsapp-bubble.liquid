{%- if settings.whatsapp_enabled and settings.whatsapp_phone != blank -%}
  {%- assign wa_digits = settings.whatsapp_phone | remove: '+' | remove: ' ' | remove: '-' | remove: '(' | remove: ')' -%}
  {%- assign wa_prefill = settings.whatsapp_prefill | default: '' | url_encode -%}
  {%- assign wa_href = 'https://wa.me/' | append: wa_digits -%}
  {%- if wa_prefill != blank -%}
    {%- assign wa_href = wa_href | append: '?text=' | append: wa_prefill -%}
  {%- endif -%}

  <style>
    .wa-bubble {
      position: fixed;
      bottom: 20px;
      {% if settings.whatsapp_position == 'left' %}left: 20px;{% else %}right: 20px;{% endif %}
      z-index: 1000;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 12px 16px 12px 14px;
      border-radius: 999px;
      background: #25D366;
      color: #FFFFFF;
      text-decoration: none;
      font-weight: 600;
      font-size: 0.875rem;
      line-height: 1;
      box-shadow: 0 6px 20px rgba(0, 0, 0, 0.18), 0 2px 6px rgba(0, 0, 0, 0.08);
      transition: transform 200ms ease, box-shadow 200ms ease;
    }
    .wa-bubble:hover,
    .wa-bubble:focus-visible {
      transform: translateY(-2px);
      box-shadow: 0 10px 28px rgba(0, 0, 0, 0.22), 0 3px 8px rgba(0, 0, 0, 0.1);
      color: #FFFFFF;
    }
    .wa-bubble__icon {
      width: 24px;
      height: 24px;
      flex-shrink: 0;
    }
    @media (max-width: 749px) {
      .wa-bubble__label { display: none; }
      .wa-bubble {
        padding: 14px;
        border-radius: 50%;
      }
    }
    @media (prefers-reduced-motion: reduce) {
      .wa-bubble { transition: none; }
      .wa-bubble:hover, .wa-bubble:focus-visible { transform: none; }
    }
  </style>

  <a
    class="wa-bubble"
    href="{{ wa_href }}"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="{{ settings.whatsapp_label | default: 'Chat with us on WhatsApp' | escape }}"
  >
    <svg class="wa-bubble__icon" viewBox="0 0 32 32" fill="currentColor" aria-hidden="true">
      <path d="M16.04 3.2C9.02 3.2 3.3 8.9 3.3 15.93c0 2.25.59 4.43 1.7 6.36L3.2 28.8l6.66-1.75a12.7 12.7 0 0 0 6.18 1.57h.01c7.02 0 12.74-5.7 12.74-12.7 0-3.39-1.32-6.58-3.73-8.98a12.7 12.7 0 0 0-9.02-3.74zm0 23.25c-1.94 0-3.84-.52-5.5-1.5l-.39-.23-3.95 1.03 1.06-3.85-.26-.4a10.6 10.6 0 0 1-1.63-5.62c0-5.85 4.77-10.6 10.65-10.6 2.84 0 5.51 1.1 7.53 3.1a10.57 10.57 0 0 1 3.12 7.51c0 5.85-4.76 10.56-10.63 10.56zm5.84-7.94c-.32-.16-1.9-.94-2.2-1.05-.3-.1-.51-.15-.73.16s-.84 1.05-1.03 1.27c-.19.21-.38.24-.7.08-.32-.16-1.36-.5-2.58-1.6-.96-.85-1.6-1.9-1.79-2.22-.19-.32-.02-.49.14-.65.14-.14.32-.37.48-.56.16-.19.21-.32.32-.53.1-.21.05-.4-.03-.56-.08-.16-.72-1.74-.99-2.38-.26-.63-.53-.54-.72-.55-.19-.01-.4-.01-.62-.01-.21 0-.56.08-.85.4-.29.32-1.12 1.1-1.12 2.67 0 1.58 1.15 3.1 1.31 3.31.16.21 2.26 3.45 5.47 4.84.76.33 1.36.53 1.82.67.77.24 1.47.2 2.02.12.62-.09 1.9-.78 2.17-1.53.27-.75.27-1.4.19-1.53-.08-.13-.29-.21-.61-.37z"/>
    </svg>
    <span class="wa-bubble__label">{{ settings.whatsapp_label | default: 'Chat with us' }}</span>
  </a>
{%- endif -%}
