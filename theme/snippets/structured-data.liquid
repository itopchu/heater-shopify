{%- comment -%}
  structured-data.liquid

  Renders schema.org JSON-LD. Included from layout/theme.liquid in <head>,
  with template-aware scope selection. All text values pulled from shop /
  product / metafields — no hardcoded copy.

  Usage:
    {%- render 'structured-data', scope: 'site' -%}
    {%- render 'structured-data', scope: 'product',     product: product -%}
    {%- render 'structured-data', scope: 'collection',  collection: collection -%}
    {%- render 'structured-data', scope: 'breadcrumbs', crumbs: crumbs -%}
{%- endcomment -%}

{%- if scope == 'site' -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": "{{ shop.url }}#org",
        "name": {{ shop.name | json }},
        "url": "{{ shop.url }}",
        {%- if settings.logo -%}
        "logo": "{{ settings.logo | image_url: width: 512 }}",
        {%- endif -%}
        "sameAs": [
          {%- assign first_item = true -%}
          {%- if settings.social_facebook_link != blank -%}
            {%- unless first_item -%},{%- endunless -%}{{ settings.social_facebook_link | json }}{%- assign first_item = false -%}
          {%- endif -%}
          {%- if settings.social_instagram_link != blank -%}
            {%- unless first_item -%},{%- endunless -%}{{ settings.social_instagram_link | json }}{%- assign first_item = false -%}
          {%- endif -%}
          {%- if settings.social_youtube_link != blank -%}
            {%- unless first_item -%},{%- endunless -%}{{ settings.social_youtube_link | json }}{%- assign first_item = false -%}
          {%- endif -%}
          {%- if settings.social_tiktok_link != blank -%}
            {%- unless first_item -%},{%- endunless -%}{{ settings.social_tiktok_link | json }}{%- assign first_item = false -%}
          {%- endif -%}
        ]
      },
      {
        "@type": "WebSite",
        "@id": "{{ shop.url }}#website",
        "url": "{{ shop.url }}",
        "name": {{ shop.name | json }},
        "publisher": { "@id": "{{ shop.url }}#org" },
        "inLanguage": "{{ request.locale.iso_code }}",
        "potentialAction": {
          "@type": "SearchAction",
          "target": "{{ shop.url }}/search?q={search_term_string}",
          "query-input": "required name=search_term_string"
        }
      }
    ]
  }
  </script>
{%- endif -%}

{%- if scope == 'product' and product -%}
  {%- assign currency = cart.currency.iso_code -%}
  {%- assign prod_url = shop.url | append: product.url -%}
  {%- assign current_variant = product.selected_or_first_available_variant -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": {{ product.title | json }},
    "description": {{ product.description | strip_html | truncate: 500 | json }},
    "sku": {{ current_variant.sku | default: product.handle | json }},
    "brand": { "@type": "Brand", "name": {{ product.vendor | json }} },
    "url": {{ prod_url | json }},
    "inLanguage": "{{ request.locale.iso_code }}",
    {%- if product.featured_image -%}
    "image": [{%- for img in product.images limit: 4 -%}"{{ img | image_url: width: 1024 }}"{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}],
    {%- endif -%}
    "offers": {%- if product.variants.size > 1 -%}[
      {%- for v in product.variants -%}
      {
        "@type": "Offer",
        "url": "{{ prod_url }}?variant={{ v.id }}",
        "sku": {{ v.sku | default: product.handle | json }},
        "priceCurrency": {{ currency | json }},
        "price": "{{ v.price | divided_by: 100.0 | round: 2 }}",
        "availability": "{% if v.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
        "itemCondition": "https://schema.org/NewCondition"
      }{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    ]{%- else -%}{
      "@type": "Offer",
      "url": {{ prod_url | json }},
      "priceCurrency": {{ currency | json }},
      "price": "{{ current_variant.price | divided_by: 100.0 | round: 2 }}",
      "availability": "{% if product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
      "itemCondition": "https://schema.org/NewCondition"
    }{%- endif -%}
    {%- if product.metafields.custom.specs.value != blank -%}
    ,
    "additionalProperty": [
      {%- assign specs_raw = product.metafields.custom.specs.value -%}
      {%- for row in specs_raw limit: 8 -%}
      {
        "@type": "PropertyValue",
        "name": {{ row.label_en | default: row.label_de | json }},
        "value": {{ row.value_en | default: row.value_de | json }}
      }{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    ]
    {%- endif -%}
    {%- comment -%}
      AggregateRating is emitted only when Judge.me has posted aggregate
      data to the product metafield `judgeme.badge`. Until S5.4's Judge.me
      install completes, this block stays silent — safer than emitting
      zero-review rating (Google flags that).
    {%- endcomment -%}
    {%- if product.metafields.judgeme.badge != blank and product.metafields.reviews.rating_count.value -%}
    ,
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "{{ product.metafields.reviews.rating.value.value | default: product.metafields.reviews.rating.value }}",
      "reviewCount": "{{ product.metafields.reviews.rating_count.value }}"
    }
    {%- endif -%}
  }
  </script>
{%- endif -%}

{%- if scope == 'collection' and collection -%}
  {%- assign col_url = shop.url | append: collection.url -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "url": {{ col_url | json }},
    "name": {{ collection.title | json }},
    "inLanguage": "{{ request.locale.iso_code }}",
    "numberOfItems": {{ collection.products_count }},
    "itemListElement": [
      {%- for p in collection.products limit: 20 -%}
      {
        "@type": "ListItem",
        "position": {{ forloop.index }},
        "item": {
          "@type": "Product",
          "name": {{ p.title | json }},
          "url": "{{ shop.url }}{{ p.url }}",
          {%- if p.featured_image -%}"image": "{{ p.featured_image | image_url: width: 600 }}",{%- endif -%}
          "offers": {
            "@type": "Offer",
            "priceCurrency": "{{ cart.currency.iso_code }}",
            "price": "{{ p.price | divided_by: 100.0 | round: 2 }}",
            "availability": "{% if p.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}"
          }
        }
      }{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    ]
  }
  </script>
{%- endif -%}

{%- if scope == 'breadcrumbs' and crumbs -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {%- for c in crumbs -%}
      { "@type": "ListItem", "position": {{ forloop.index }}, "name": {{ c.name | json }}, "item": {{ c.url | json }} }{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    ]
  }
  </script>
{%- endif -%}
