{%- comment -%}
  Branded fallback rendered when a synced product has no media attached.
  Pure inline SVG — no external assets, no file uploads.

  Accepts:
    - alt_text: optional accessible label. Default: product title or a neutral string.
{%- endcomment -%}

{%- assign resolved_alt = alt_text | default: 'Product image coming soon' -%}
<svg
  class="gberg-placeholder"
  viewBox="0 0 800 800"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label="{{ resolved_alt | escape }}"
  preserveAspectRatio="xMidYMid meet"
  style="width:100%;height:100%;display:block;background:#F7F7F7"
>
  <rect width="800" height="800" fill="#F7F7F7"/>
  <g transform="translate(220 220)" fill="none" stroke="#C8102E" stroke-width="6" stroke-linejoin="round">
    <rect x="0" y="0" width="360" height="280" rx="10"/>
    <line x1="40"  y1="24" x2="40"  y2="256"/>
    <line x1="100" y1="24" x2="100" y2="256"/>
    <line x1="160" y1="24" x2="160" y2="256"/>
    <line x1="220" y1="24" x2="220" y2="256"/>
    <line x1="280" y1="24" x2="280" y2="256"/>
    <line x1="320" y1="24" x2="320" y2="256"/>
    <line x1="-30" y1="70"  x2="0"   y2="70"/>
    <line x1="-30" y1="210" x2="0"   y2="210"/>
    <line x1="360" y1="70"  x2="390" y2="70"/>
    <line x1="360" y1="210" x2="390" y2="210"/>
  </g>
  <text
    x="400" y="605"
    fill="#111111"
    font-family="Fraunces, Georgia, serif"
    font-size="56"
    font-weight="600"
    text-anchor="middle"
  >G-Berg</text>
  <text
    x="400" y="655"
    fill="#666666"
    font-family="Inter, system-ui, sans-serif"
    font-size="22"
    text-anchor="middle"
  >{{ 'products.placeholder.caption' | t }}</text>
</svg>
